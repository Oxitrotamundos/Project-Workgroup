{
  "name": "project-workgroup",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:shared": "pnpm --filter @project-workgroup/shared run build",
    "dev": "pnpm run build:shared && concurrently -n web,api -c auto \"pnpm:dev:web\" \"pnpm:dev:api\"",
    "dev:web": "pnpm --filter @project-workgroup/web run dev",
    "dev:api": "pnpm --filter @project-workgroup/api run start:dev",
    "build": "pnpm run build:shared && pnpm --filter @project-workgroup/web run build && pnpm --filter @project-workgroup/api run build",
    "lint": "pnpm --filter @project-workgroup/web run lint && pnpm --filter @project-workgroup/api run lint",
    "test": "pnpm run build:shared && pnpm --filter @project-workgroup/web run test:run && pnpm --filter @project-workgroup/api run test",
    "db:up": "docker compose -f apps/api/docker-compose.dev.yml up -d",
    "db:down": "docker compose -f apps/api/docker-compose.dev.yml down",
    "migrate": "pnpm --filter @project-workgroup/api exec prisma migrate dev",
    "seed": "pnpm --filter @project-workgroup/api exec prisma db seed",
    "api:openapi:dump": "pnpm --filter @project-workgroup/api run openapi:dump",
    "api:openapi:check": "pnpm --filter @project-workgroup/api run openapi:check"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": ">=8.4.1",
      "fast-xml-parser": ">=4.5.3",
      "fast-xml-builder": ">=1.1.7",
      "glob": ">=10.5.0",
      "picomatch": ">=4.0.4",
      "fast-uri": ">=3.1.2",
      "lodash": ">=4.18.0",
      "multer": ">=2.2.0",
      "hono": ">=4.12.25",
      "@hono/node-server": ">=1.19.13",
      "uuid": ">=11.1.1",
      "@tootallnate/once": ">=2.0.1",
      "brace-expansion": ">=5.0.6",
      "minimatch>brace-expansion": "^1.1.11",
      "file-type": ">=21.3.2",
      "ajv": ">=8.18.0",
      "@eslint/eslintrc>ajv": "^6.14.0",
      "eslint>ajv": "^6.14.0",
      "webpack": ">=5.104.1",
      "js-yaml": ">=4.1.1",
      "tmp": ">=0.2.6",
      "shell-quote": ">=1.8.4",
      "@grpc/grpc-js": ">=1.14.4",
      "ws": ">=7.5.11",
      "form-data": ">=4.0.6",
      "undici": ">=7.28.0"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "msw",
      "prisma"
    ]
  }
}
